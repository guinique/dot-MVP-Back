# Application
APP_NAME=dot-MVP-Back
DEBUG=true

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./dot_mvp.db

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Embed authentication (header X-Embed-Token)
EMBED_API_KEY=change-me-embed-key

# LLM — Groq free tier: https://console.groq.com
# Use LLM_PROVIDER=mock for local dev/tests without API key
LLM_PROVIDER=groq
GROQ_API_KEY=
# llama-3.3-70b-versatile handles tool calling more reliably than 8b models
GROQ_MODEL=llama-3.3-70b-versatile

# Chat history context window
CHAT_HISTORY_LIMIT=20

# LangSmith (optional) — https://smith.langchain.com
# Traces LangChain agent runs: tool calls, prompts, responses
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dot-mvp
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
